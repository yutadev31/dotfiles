#!/bin/zsh

alias '$'=

# --color=auto
alias ls="ls --color=auto"
alias grep="grep --color=auto"
alias diff="diff --color=auto"

# -i
alias mv="mv -i"
alias rm="rm -i"
alias rmrf="rm -rf"
alias cp="cp -i"

alias cl="clear"

# ls
alias ll="ls -l"
alias la="ls -la"

# sudo
alias pacman="sudo pacman"
alias apt="sudo apt"
alias reboot="sudo reboot"
alias shutdown="sudo shutdown -h now"

# git
alias lg="lazygit"
alias ga="git add"
alias gaa="git add ."
alias gc="git commit"
alias gcinit="git commit -m \"Initial commit\""
alias gp="git push"

# python
alias py="python3"

